<?xml version="1.0" encoding="UTF-8" ?>
<Page x:ConnectionId='1'
    x:Class="FastPick.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FastPick"
    xmlns:models="using:FastPick.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PageBackgroundBrush}"
                                        >

    <Page.Resources>
        <!-- 页面级资源覆盖 -->
        
        <!-- 缩略图项数据模板 - 用于 ItemsRepeater -->
        <DataTemplate x:Key="ThumbnailItemTemplate">
            <Grid x:Name="ThumbnailGrid"
                  Width="100" 
                  Height="120"
                  Background="{StaticResource ElevatedBackgroundBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                
                <!-- 图片区域 - 使用 Viewbox 确保正比例缩放 -->
                <Viewbox Grid.Row="0" 
                         Stretch="Uniform"
                         Margin="4">
                    <Image x:Name="ThumbnailImage"
                           Source="{Binding Thumbnail}"
                           Stretch="UniformToFill"/>
                </Viewbox>
                
                <!-- 预删除角标 -->
                <Border x:Name="DeleteBadge"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{StaticResource DangerBrush}"
                        Width="16"
                        Height="16"
                        CornerRadius="8"
                        Margin="2"
                        Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="&#xE74D;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="10"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                
                <!-- 文件类型角标 -->
                <Border x:Name="FileTypeBadge"
                        Grid.Row="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="{StaticResource AccentBrush}"
                        Padding="4,2"
                        CornerRadius="2"
                        Margin="2">
                    <TextBlock x:Name="FileTypeText"
                               FontSize="8"
                               Foreground="White"
                               Text="{Binding FileType, Converter={StaticResource FileTypeToStringConverter}}"/>
                </Border>
                
                <!-- 底部信息栏 -->
                <Grid Grid.Row="1"
                      Background="{StaticResource SurfaceBackgroundBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,1,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 文件名 -->
                    <TextBlock x:Name="FileNameText"
                               Grid.Column="0"
                               Text="{Binding FileName}"
                               FontSize="10"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="4,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <!-- 星级 -->
                    <TextBlock x:Name="RatingText"
                               Grid.Column="1"
                               Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                               FontSize="10"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding Rating, Converter={StaticResource RatingToVisibilityConverter}}"/>
                </Grid>
            </Grid>
        </DataTemplate>
        
        <!-- 多选预览数据模板 -->
        <DataTemplate x:Key="MultiPreviewTemplate">
            <Grid Width="160" Height="120" Margin="4">
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                <Border Background="#80000000" 
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Padding="4,2">
                    <TextBlock x:Name="PreviewFileName"
                               Foreground="White"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <!-- 五段式布局 -->
    <Grid x:ConnectionId='12' x:Name="MainLayout">
        <Grid.RowDefinitions>
            <!-- Row 0: 标题栏 (缩窄20%: 48px -> 38px) -->
            <RowDefinition Height="42" />
            <!-- Row 1: 抽屉区 -->
            <RowDefinition Height="Auto" />
            <!-- Row 2: 预览区 -->
            <RowDefinition Height="*" />
            <!-- Row 3: 缩略图区 -->
            <RowDefinition Height="180" />
            <!-- Row 4: 底部工具栏 -->
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <!-- ==================== 标题栏 (Row 0) ==================== -->
        <Grid x:ConnectionId='13' x:Name="TitleBarGrid" 
              Grid.Row="0" 
              Background="{StaticResource SurfaceBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧功能按钮（图标化） -->
            <StackPanel x:ConnectionId='61' x:Name="TitleBarButtonsPanel" Grid.Column="0" Orientation="Horizontal" Margin="8,0" Spacing="4">
                <Button x:ConnectionId='64' x:Name="PathButton"
                        Content="&#xE8B7;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                
                        ToolTipService.ToolTip="路径" />
                <Button x:ConnectionId='65' x:Name="ExportButton"
                        Content="&#xea35;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                  
                        ToolTipService.ToolTip="导出" />
                <Button x:ConnectionId='66' x:Name="DeleteButton"
                        Content="&#xE74D;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource DangerIconButtonStyle}"
                                                  
                        ToolTipService.ToolTip="删除" />
                <Button x:ConnectionId='67' x:Name="FilterButton"
                        Content="&#xE71C;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                  
                        ToolTipService.ToolTip="筛选" />
                <Button x:ConnectionId='68' x:Name="SettingsButton"
                        Content="&#xE713;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                    
                        ToolTipService.ToolTip="设置" />
            </StackPanel>

            <!-- 中间标题（可拖拽区域） -->
            <TextBlock x:ConnectionId='62' Grid.Column="1"
                       x:Name="TitleBarText"
                       Text="FastPick"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <!-- 右侧窗口控制（使用系统标题栏按钮） -->
            <StackPanel x:ConnectionId='63' Grid.Column="2" Orientation="Horizontal" Margin="8,0" x:Name="WindowControlsPanel">
            </StackPanel>
        </Grid>

        <!-- ==================== 抽屉区 (Row 1) ==================== -->
        <!-- 路径抽屉 -->
        <Border x:ConnectionId='14' x:Name="PathDrawer"
                Grid.Row="1"
                Style="{StaticResource DrawerContentStyle}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="路径1:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBox x:ConnectionId='56' x:Name="Path1TextBox" 
                         Width="300" 
                         PlaceholderText="选择文件夹..."
                         Style="{StaticResource DarkTextBoxStyle}" />
                <Button x:ConnectionId='57' Content="&#xE838;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                       
                        ToolTipService.ToolTip="选择文件夹" />

                <TextBlock Text="路径2:" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBox x:ConnectionId='58' x:Name="Path2TextBox" 
                         Width="300" 
                         PlaceholderText="选择文件夹..."
                         Style="{StaticResource DarkTextBoxStyle}" />
                <Button x:ConnectionId='59' Content="&#xE838;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                       
                        ToolTipService.ToolTip="选择文件夹" />

                <Button x:ConnectionId='60' Content="&#xE72C;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource PrimaryButtonStyle}"
                                                
                        ToolTipService.ToolTip="载入" />
            </StackPanel>
        </Border>

        <!-- 导出抽屉 -->
        <Border x:ConnectionId='15' x:Name="ExportDrawer"
                Grid.Row="1"
                Style="{StaticResource DrawerContentStyle}"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- 第一行：RAW导出控制 + 文件夹配置 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
                    <TextBlock Text="RAW导出控制:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <ComboBox x:ConnectionId='53' x:Name="ExportRatingComboBox" 
                              Width="120" 
                              SelectedIndex="0"
                              Style="{StaticResource DarkComboBoxStyle}">
                        <ComboBoxItem Content="5星以上" />
                        <ComboBoxItem Content="4星以上" />
                        <ComboBoxItem Content="3星以上" />
                        <ComboBoxItem Content="2星以上" />
                        <ComboBoxItem Content="1星以上" />
                    </ComboBox>

                    <TextBlock Text="JPG文件夹:" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBox x:ConnectionId='54' x:Name="JpgFolderTextBox" 
                             Width="100" 
                             Text="JPG"
                             Style="{StaticResource DarkTextBoxStyle}" />

                    <TextBlock Text="RAW文件夹:" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBox x:ConnectionId='55' x:Name="RawFolderTextBox" 
                             Width="100" 
                             Text="RAW"
                             Style="{StaticResource DarkTextBoxStyle}" />
                </StackPanel>
                
                <!-- 第二行：导出路径 + 导出按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="导出位置:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBox x:ConnectionId='50' x:Name="ExportPathTextBox" 
                             Width="300" 
                             PlaceholderText="选择导出路径..."
                             Style="{StaticResource DarkTextBoxStyle}" />
                    <Button x:ConnectionId='51' Content="&#xE8B7;"
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource IconButtonStyle}"
                                                                
                            ToolTipService.ToolTip="浏览" />

                    <Button x:ConnectionId='52' Content="&#xE898;"
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource PrimaryButtonStyle}"
                                                             
                            ToolTipService.ToolTip="导出" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 删除抽屉 -->
        <Border x:ConnectionId='16' x:Name="DeleteDrawer"
                Grid.Row="1"
                Style="{StaticResource DrawerContentStyle}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="当前预删除：" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Run x:ConnectionId='49' x:Name="DeleteCountRun" Text="0张" Foreground="{StaticResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>

                <RadioButton x:ConnectionId='45' x:Name="DeleteBothRadio" 
                             Content="同时删除" 
                             IsChecked="True"
                             Style="{StaticResource DarkRadioButtonStyle}" />
                <RadioButton x:ConnectionId='46' x:Name="DeleteJpgOnlyRadio" 
                             Content="仅删除JPG"
                             Style="{StaticResource DarkRadioButtonStyle}" />
                <RadioButton x:ConnectionId='47' x:Name="DeleteRawOnlyRadio" 
                             Content="仅删除RAW"
                             Style="{StaticResource DarkRadioButtonStyle}" />

                <Button x:ConnectionId='48' Content="&#xE74D;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource DangerIconButtonStyle}"
                                                         
                        ToolTipService.ToolTip="执行删除" />
            </StackPanel>
        </Border>

        <!-- 筛选抽屉 -->
        <Border x:ConnectionId='17' x:Name="FilterDrawer"
                Grid.Row="1"
                Style="{StaticResource DrawerContentStyle}"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- 第一行：文件类型筛选 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
                    <TextBlock Text="文件类型:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <RadioButton x:ConnectionId='41' x:Name="FilterAllRadio" 
                                 Content="全部" 
                                 IsChecked="True"
                                 Style="{StaticResource DarkRadioButtonStyle}" />
                    <RadioButton x:ConnectionId='42' x:Name="FilterBothRadio" 
                                 Content="双文件"
                                 Style="{StaticResource DarkRadioButtonStyle}" />
                    <RadioButton x:ConnectionId='43' x:Name="FilterJpgOnlyRadio" 
                                 Content="仅JPG"
                                 Style="{StaticResource DarkRadioButtonStyle}" />
                    <RadioButton x:ConnectionId='44' x:Name="FilterRawOnlyRadio" 
                                 Content="仅RAW"
                                 Style="{StaticResource DarkRadioButtonStyle}" />
                </StackPanel>
                
                <!-- 第二行：星级筛选 + 应用按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="星级:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <ComboBox x:ConnectionId='38' x:Name="FilterRatingComboBox" 
                              Width="100" 
                              SelectedIndex="0"
                              Style="{StaticResource DarkComboBoxStyle}">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="有星" />
                        <ComboBoxItem Content="无星" />
                        <ComboBoxItem Content="等于" />
                        <ComboBoxItem Content="大于等于" />
                        <ComboBoxItem Content="小于等于" />
                    </ComboBox>

                    <ComboBox x:ConnectionId='39' x:Name="FilterStarCountComboBox" 
                              Width="80" 
                              SelectedIndex="5"
                              Style="{StaticResource DarkComboBoxStyle}">
                        <ComboBoxItem Content="0星" />
                        <ComboBoxItem Content="1星" />
                        <ComboBoxItem Content="2星" />
                        <ComboBoxItem Content="3星" />
                        <ComboBoxItem Content="4星" />
                        <ComboBoxItem Content="5星" />
                    </ComboBox>

                    <Button x:ConnectionId='40' Content="&#xE73E;"
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource PrimaryButtonStyle}"
                                                           
                            ToolTipService.ToolTip="应用筛选" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 设置抽屉 -->
        <Border x:ConnectionId='18' x:Name="SettingsDrawer"
                Grid.Row="1"
                Style="{StaticResource DrawerContentStyle}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="设置选项将在后续版本中添加" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                <Button x:ConnectionId='36' Content="&#xE74E;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource PrimaryButtonStyle}"
                                                        
                        ToolTipService.ToolTip="保存" />
                <Button x:ConnectionId='37' Content="&#xE711;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                                                          
                        ToolTipService.ToolTip="取消" />
            </StackPanel>
        </Border>

        <!-- ==================== 预览区 + 缩略图区容器 (Row 2-3) ==================== -->
        <Grid Grid.Row="2" Grid.RowSpan="2" Background="{StaticResource PageBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!-- 预览区 -->
            <Grid Grid.Row="0">
                <!-- 单图预览 -->
                <Image x:ConnectionId='33' x:Name="PreviewImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Visible" />

                <!-- 多图平铺预览 -->
                <GridView x:ConnectionId='34' x:Name="MultiPreviewGrid"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          MaxWidth="1000">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>

                <!-- 加载进度环 -->
                <ProgressRing x:ConnectionId='35' x:Name="LoadingRing"
                              IsActive="False"
                              Width="50"
                              Height="50"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource AccentBrush}" />
            </Grid>

            <!-- 缩略图区 - 使用 ItemsRepeater 实现虚拟滚动 -->
            <Grid Grid.Row="1"
                  Background="{StaticResource SurfaceBackgroundBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="0,1,0,0">
                <ScrollViewer x:ConnectionId='31' x:Name="ThumbnailScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              IsVerticalScrollChainingEnabled="False"
                                                                                             >
                    <ItemsRepeater x:ConnectionId='32' x:Name="ThumbnailRepeater"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="8"
                                   ItemTemplate="{StaticResource ThumbnailItemTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>

            <!-- ==================== 右侧文件信息抽屉 ==================== -->
            <!-- 覆盖预览区+缩略图区，高度自适应 -->
            <Border x:ConnectionId='22' x:Name="FileInfoDrawer"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Background="{StaticResource AcrylicSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Width="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource ElevatedBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Text="文件信息" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontWeight="Bold" 
                                   FontSize="16" />
                    </Border>

                    <!-- 内容 -->
                    <ScrollViewer Grid.Row="1" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock x:ConnectionId='24' x:Name="FileNameTextBlock" Text="文件名: -" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:ConnectionId='25' x:Name="FilePathTextBlock" Text="路径: -" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:ConnectionId='26' x:Name="FileSizeTextBlock" Text="大小: -" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:ConnectionId='27' x:Name="FileDimensionsTextBlock" Text="尺寸: -" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:ConnectionId='28' x:Name="FileRatingTextBlock" Text="评级: -" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:ConnectionId='29' x:Name="FileTypeTextBlock" Text="类型: -" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:ConnectionId='30' x:Name="FileDateTextBlock" Text="修改日期: -" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2" 
                            Padding="16" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="0,1,0,0">
                        <Button x:ConnectionId='23' Content="&#xE838; 打开"
                                FontFamily="Segoe Fluent Icons, Segoe UI Variable Text"
                                HorizontalAlignment="Stretch"
                                                                  
                                Style="{StaticResource IconTextButtonStyle}"
                                ToolTipService.ToolTip="在资源管理器中打开" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== 底部工具栏 (Row 4) ==================== -->
        <Grid Grid.Row="4" 
              Background="{StaticResource SurfaceBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：文件信息按钮（图标化） -->
            <Button x:ConnectionId='19' x:Name="FileInfoButton"
                    Grid.Column="0"
                    Content="&#xE946;"
                    FontFamily="Segoe Fluent Icons"
                    Margin="8,0"
                    Style="{StaticResource IconButtonStyle}"
                                                
                    ToolTipService.ToolTip="文件信息" />

            <!-- 中间：缩放控制 -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="缩放:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                <ComboBox x:ConnectionId='20' x:Name="ZoomComboBox" 
                          Width="110" 
                          SelectedIndex="1"
                          Style="{StaticResource DarkComboBoxStyle}">
                    <ComboBoxItem Content="50%" />
                    <ComboBoxItem Content="60%" />
                    <ComboBoxItem Content="75%" />
                    <ComboBoxItem Content="100%" />
                    <ComboBoxItem Content="125%" />
                    <ComboBoxItem Content="150%" />
                    <ComboBoxItem Content="200%" />
                </ComboBox>
                <Button x:ConnectionId='21' Content="&#xE71E;"
                        FontFamily="Segoe Fluent Icons"
                        ToolTipService.ToolTip="适应窗口"
                                                       
                        Style="{StaticResource TitleBarButtonStyle}" />
            </StackPanel>
        </Grid>

    </Grid>
</Page>

