<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- FastPick 深色主题资源字典 -->
    <!-- 基于 Fluent Design 黑色主题规范 -->
    <!-- ============================================ -->

    <!-- 基础色彩资源 -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ElevatedBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="#444444"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#252525"/>

    <!-- 文本颜色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#666666"/>

    <!-- 强调色 -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1089FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#006CBD"/>

    <!-- 功能色 -->
    <SolidColorBrush x:Key="DangerBrush" Color="#ffffffff"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#d48384ff"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#1089FF"/>

    <!-- 边框和分割线 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="#404040"/>
    <SolidColorBrush x:Key="AccentBorderBrush" Color="#0078D4"/>

    <!-- Acrylic 毛玻璃效果（使用纯色作为回退） -->
    <SolidColorBrush x:Key="AcrylicSurfaceBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AcrylicElevatedBrush" Color="#2D2D2D"/>

    <!-- ============================================ -->
    <!-- 标题栏按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ============================================ -->
    <!-- 主操作按钮样式（强调色） -->
    <!-- ============================================ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================ -->
    <!-- 危险操作按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================ -->
    <!-- 成功操作按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="SuccessButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================ -->
    <!-- 输入框样式 -->
    <!-- ============================================ -->
    <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================ -->
    <!-- 下拉框样式 -->
    <!-- ============================================ -->
    <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ElevatedBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- ============================================ -->
    <!-- 单选按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="DarkRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================ -->
    <!-- 抽屉内容样式 -->
    <!-- ============================================ -->
    <Style x:Key="DrawerContentStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>

    <!-- ============================================ -->
    <!-- 右侧抽屉样式 -->
    <!-- ============================================ -->
    <Style x:Key="RightDrawerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AcrylicSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
        <Setter Property="Width" Value="320"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <!-- ============================================ -->
    <!-- 缩略图项样式 -->
    <!-- ============================================ -->
    <Style x:Key="ThumbnailItemStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource ElevatedBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ============================================ -->
    <!-- 图标按钮样式（适配38px标题栏） -->
    <!-- ============================================ -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ============================================ -->
    <!-- 图标+文字按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="IconTextButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe UI Variable Text"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="{StaticResource ElevatedBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- ============================================ -->
    <!-- 危险图标按钮样式（适配38px标题栏） -->
    <!-- ============================================ -->
    <Style x:Key="DangerIconButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ============================================ -->
    <!-- 全局页面样式 -->
    <!-- ============================================ -->
    <Style TargetType="Page">
        <Setter Property="Background" Value="{StaticResource PageBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

</ResourceDictionary>
